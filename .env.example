# =============================================================================
# Memory Palace - Configuration
# =============================================================================
# Copy to .env and edit:
#   cp .env.example .env
# Or generate from profiles:
#   bash scripts/apply_profile.sh macos b
#   # Windows: .\scripts\apply_profile.ps1 -Platform windows -Profile b
# Profile templates under deploy/profiles/ are source templates, not final env files.
# Generate .env / .env.docker through apply_profile.* instead of copying them directly.
#   # Switch to profile c only after your embedding / reranker endpoints are ready
#
# Unified C/D note:
# - Phase C/D uses the same hybrid retrieval pipeline.
# - First tuning knob: RETRIEVAL_RERANKER_WEIGHT.
# =============================================================================

# SQLite database path (must be absolute)
# Replace this with your real local path before first run.
DATABASE_URL=sqlite+aiosqlite:////REPLACE/WITH/YOUR/ABSOLUTE/PATH/memory_palace/demo.db

# Schema migration lock (prevents concurrent migration conflicts)
# Optional: if empty, defaults to "<db_file>.migrate.lock" beside DATABASE_URL target.
DB_MIGRATION_LOCK_FILE=
DB_MIGRATION_LOCK_TIMEOUT_SEC=10

# Memory URI domains (reserved read-only `system://` is built-in and does not
# need to appear here)
VALID_DOMAINS=core,writer,game,notes

# Auto-loaded memories on system://boot
CORE_MEMORY_URIS=core://agent,core://my_user,core://agent/my_user

# =============================================================================
# Retrieval / Search
# =============================================================================
# keyword | semantic | hybrid
# For Unified C/D, set this to hybrid.
SEARCH_DEFAULT_MODE=keyword

SEARCH_DEFAULT_MAX_RESULTS=10
SEARCH_DEFAULT_CANDIDATE_MULTIPLIER=4
DEFAULT_INTERACTION_TIER=fast
FAST_INTERACTION_CANDIDATE_MULTIPLIER=4
DEEP_INTERACTION_CANDIDATE_MULTIPLIER=8
SEARCH_HARD_MAX_RESULTS=100
SEARCH_HARD_MAX_CANDIDATE_MULTIPLIER=50

RETRIEVAL_CHUNK_SIZE=1000
RETRIEVAL_CHUNK_OVERLAP=200

# Hybrid score weights
RETRIEVAL_HYBRID_KEYWORD_WEIGHT=0.7
RETRIEVAL_HYBRID_SEMANTIC_WEIGHT=0.3
RETRIEVAL_WEIGHT_PRIORITY=0.1
RETRIEVAL_WEIGHT_RECENCY=0.06
RETRIEVAL_WEIGHT_PATH_PREFIX=0.04
RETRIEVAL_RECENCY_HALF_LIFE_DAYS=30

# Optional MMR diversification (advanced; default off)
RETRIEVAL_MMR_ENABLED=false
RETRIEVAL_MMR_LAMBDA=0.65
RETRIEVAL_MMR_CANDIDATE_FACTOR=3

# Embedding backend:
# - hash: built-in local hash embedding
# - none: disable semantic index (fallback keyword)
# - router/api/openai: call OpenAI-compatible /embeddings API
# IMPORTANT: even local model servers should be configured via *_API_BASE/*_API_KEY/*_MODEL.
RETRIEVAL_EMBEDDING_BACKEND=none
RETRIEVAL_EMBEDDING_MODEL=your-embedding-model-id
RETRIEVAL_EMBEDDING_DIM=64
RETRIEVAL_EMBEDDING_API_BASE=
RETRIEVAL_EMBEDDING_API_KEY=
RETRIEVAL_REMOTE_TIMEOUT_SEC=8
# Optional explicit allowlist for trusted private provider IP literals or CIDRs.
# Loopback (`127.0.0.1`, `::1`, `localhost`) stays allowed by default.
MEMORY_PALACE_ALLOWED_PRIVATE_PROVIDER_TARGETS=

# Optional router aliases (mainly for managed / production deployments).
# Local development can leave ROUTER_* empty and directly configure
# RETRIEVAL_EMBEDDING_* / RETRIEVAL_RERANKER_* / WRITE_GUARD_LLM_* instead.
ROUTER_API_BASE=
ROUTER_API_KEY=
ROUTER_EMBEDDING_MODEL=your-embedding-model-id

# Optional reranker (OpenAI-compatible style endpoint)
RETRIEVAL_RERANKER_ENABLED=false
RETRIEVAL_RERANKER_API_BASE=
RETRIEVAL_RERANKER_API_KEY=
RETRIEVAL_RERANKER_MODEL=your-reranker-model-id

# First tuning knob for Unified C/D.
# Typical range: 0.20 ~ 0.40
RETRIEVAL_RERANKER_WEIGHT=0.40

# =============================================================================
# LLM Decisions (Write Guard / Compact Gist)
# =============================================================================
# OpenAI-compatible chat endpoint (expects /chat/completions support).
WRITE_GUARD_LLM_ENABLED=false
WRITE_GUARD_LLM_API_BASE=
WRITE_GUARD_LLM_API_KEY=
WRITE_GUARD_LLM_MODEL=your-chat-model-id

# compact_context gist stage-1 LLM.
# If COMPACT_GIST_LLM_* is empty, runtime falls back to WRITE_GUARD_LLM_*.
COMPACT_GIST_LLM_ENABLED=false
COMPACT_GIST_LLM_API_BASE=
COMPACT_GIST_LLM_API_KEY=
COMPACT_GIST_LLM_MODEL=your-chat-model-id

# Optional intent LLM (experimental; falls back to keyword rules when disabled or unavailable)
INTENT_LLM_ENABLED=false
INTENT_LLM_API_BASE=
INTENT_LLM_API_KEY=
INTENT_LLM_MODEL=your-chat-model-id

# Compatibility note:
# Runtime still accepts some historical alias/fallback sources (such as LLM_*,
# OPENAI_*, ROUTER_* and legacy *_BASE/*_KEY forms), but prefer the explicit
# service-specific keys above in new deployments.
#
# Prompt safety / reflection lane:
# Optional LLM-assisted guard / gist / intent calls run through a bounded
# reflection lane and treat input payloads as untrusted data by default.
RUNTIME_REFLECTION_LANE_ENABLED=true
RUNTIME_REFLECTION_GLOBAL_CONCURRENCY=2
RUNTIME_REFLECTION_ACQUIRE_TIMEOUT_SECONDS=20
PROMPT_SAFETY_MAX_INPUT_CHARS=4000
PROMPT_SAFETY_MAX_CANDIDATE_CHARS=480

# =============================================================================
# Runtime / Queue / Index Worker
# =============================================================================
RUNTIME_SESSION_FIRST_SEARCH=true

RUNTIME_WRITE_LANE_QUEUE=true
RUNTIME_WRITE_GLOBAL_CONCURRENCY=1
RUNTIME_WRITE_WAIT_WARN_MS=2000

RUNTIME_SESSION_CACHE_MAX_HITS=200
RUNTIME_SESSION_CACHE_MAX_SESSIONS=128
RUNTIME_SESSION_CACHE_HALF_LIFE_SECONDS=21600

RUNTIME_INDEX_WORKER_ENABLED=true
RUNTIME_INDEX_DEFER_ON_WRITE=true
RUNTIME_INDEX_QUEUE_MAXSIZE=256
RUNTIME_INDEX_RECENT_JOBS=30
RUNTIME_VITALITY_DECAY_CHECK_INTERVAL_SECONDS=600
RUNTIME_CLEANUP_REVIEW_TTL_SECONDS=900
RUNTIME_CLEANUP_REVIEW_MAX_PENDING=64

# Maintenance API gate (protects /maintenance/*, /review/*, /browse/*, /sse and /messages)
# Accepts either:
# - X-MCP-API-Key: <MCP_API_KEY>
# - Authorization: Bearer <MCP_API_KEY>
MCP_API_KEY=
# Default is fail-closed when MCP_API_KEY is empty.
# Docker profile helper scripts (`apply_profile.*` with `docker` platform) will
# auto-generate a local MCP_API_KEY when this value is left empty.
# Enable only for local debugging when you explicitly accept insecure access.
MCP_API_KEY_ALLOW_INSECURE_LOCAL=false
# Per-session burst guard for authenticated `/messages` POST traffic.
# Returns HTTP 429 with `Retry-After` when a single SSE session exceeds the window.
SSE_MESSAGE_RATE_LIMIT_WINDOW_SECONDS=10
SSE_MESSAGE_RATE_LIMIT_MAX_REQUESTS=120
# Hard body-size ceiling for one `/messages` POST payload.
# Returns HTTP 413 before parsing JSON when the payload is too large.
SSE_MESSAGE_MAX_BODY_BYTES=1048576

# HTTP / CORS
# Leave CORS_ALLOW_ORIGINS empty to use the built-in local defaults:
# localhost / 127.0.0.1 on ports 5173 and 3000.
CORS_ALLOW_ORIGINS=
CORS_ALLOW_CREDENTIALS=true
# Docker frontend only. Leave empty to keep CSP connect-src on the default `'self'`.
# Example for split-origin admin deployments:
# FRONTEND_CSP_CONNECT_SRC='self' https://api.example.com wss://api.example.com
FRONTEND_CSP_CONNECT_SRC=

RUNTIME_AUTO_FLUSH_ENABLED=true
RUNTIME_AUTO_FLUSH_PARENT_URI=notes://
RUNTIME_AUTO_FLUSH_PRIORITY=2
RUNTIME_AUTO_FLUSH_SUMMARY_LINES=12
RUNTIME_FLUSH_TRIGGER_CHARS=6000
RUNTIME_FLUSH_MIN_EVENTS=6
RUNTIME_FLUSH_MAX_EVENTS=80
RUNTIME_FLUSH_MAX_SESSIONS=128
RUNTIME_GUARD_EVENT_LIMIT=300
RUNTIME_IMPORT_LEARN_AUDIT_LIMIT=300
RUNTIME_PROMOTION_EVENT_LIMIT=200
RUNTIME_SLEEP_CONSOLIDATION_ENABLED=true
RUNTIME_SLEEP_CONSOLIDATION_INTERVAL_SECONDS=1800
RUNTIME_SLEEP_DEDUP_APPLY=false
RUNTIME_SLEEP_FRAGMENT_ROLLUP_APPLY=false
INDEX_LITE_ENABLED=false
AUDIT_VERBOSE=false
OBSERVABILITY_CLEANUP_QUERY_SLOW_MS=250

# =============================================================================
# Vitality / Cleanup 
# =============================================================================
VITALITY_MAX_SCORE=3.0
VITALITY_REINFORCE_DELTA=0.08
VITALITY_DECAY_HALF_LIFE_DAYS=30
VITALITY_DECAY_MIN_SCORE=0.05
VITALITY_CLEANUP_THRESHOLD=0.35
VITALITY_CLEANUP_INACTIVE_DAYS=14

# =============================================================================
# HOLD Defaults (#5/#6/#11/#12/#13) - fail-closed
# =============================================================================
# #5 External import (default off)
EXTERNAL_IMPORT_ENABLED=false
EXTERNAL_IMPORT_ALLOWED_DOMAINS=notes
EXTERNAL_IMPORT_ALLOWED_ROOTS=
EXTERNAL_IMPORT_ALLOWED_EXTS=.md,.txt,.json
EXTERNAL_IMPORT_MAX_TOTAL_BYTES=5242880
EXTERNAL_IMPORT_MAX_FILES=200
EXTERNAL_IMPORT_RATE_LIMIT_WINDOW_SECONDS=60
EXTERNAL_IMPORT_RATE_LIMIT_MAX_REQUESTS=10
EXTERNAL_IMPORT_RATE_LIMIT_STATE_FILE=
EXTERNAL_IMPORT_REQUIRE_SHARED_RATE_LIMIT=false

# #6 Explicit auto-learn trigger (default off)
AUTO_LEARN_EXPLICIT_ENABLED=false
AUTO_LEARN_ALLOWED_DOMAINS=notes
AUTO_LEARN_REQUIRE_REASON=true

# #11 Embedding provider chain (default off)
EMBEDDING_PROVIDER_CHAIN_ENABLED=false
EMBEDDING_PROVIDER_FAIL_OPEN=false
EMBEDDING_PROVIDER_FALLBACK=hash

# #12 sqlite-vec rollout controls (default legacy)
RETRIEVAL_SQLITE_VEC_ENABLED=false
RETRIEVAL_SQLITE_VEC_EXTENSION_PATH=
RETRIEVAL_VECTOR_ENGINE=legacy
RETRIEVAL_SQLITE_VEC_READ_RATIO=0

# #13 Write lane + WAL controls (default delete mode)
# If multiple CLI / IDE processes share the same SQLite file, prefer WAL mode
# and raise RUNTIME_WRITE_BUSY_TIMEOUT_MS to 5000 or higher.
RUNTIME_WRITE_WAL_ENABLED=false
RUNTIME_WRITE_JOURNAL_MODE=delete
RUNTIME_WRITE_WAL_SYNCHRONOUS=normal
RUNTIME_WRITE_BUSY_TIMEOUT_MS=5000
RUNTIME_WRITE_WAL_AUTOCHECKPOINT=1000
