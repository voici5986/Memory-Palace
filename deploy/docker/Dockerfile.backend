FROM python:3.11-slim@sha256:233de06753d30d120b1a3ce359d8d3be8bda78524cd8f520c99883bfe33964cf

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app/backend

RUN apt-get update \
    && apt-get install -y --no-install-recommends gosu \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system --gid 10001 app \
    && useradd --system --uid 10001 --gid 10001 --create-home app

COPY backend/requirements.txt /app/backend/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY backend /app/backend
COPY deploy/docker/backend-entrypoint.sh /usr/local/bin/backend-entrypoint.sh
COPY deploy/docker/backend-healthcheck.py /usr/local/bin/backend-healthcheck.py
RUN chmod +x /usr/local/bin/backend-entrypoint.sh /usr/local/bin/backend-healthcheck.py \
    && sed -i 's/\r$//' /usr/local/bin/backend-entrypoint.sh \
    && mkdir -p /app/data /app/snapshots \
    && chown -R app:app /app/backend /app/data /app/snapshots

EXPOSE 8000

ENTRYPOINT ["/usr/local/bin/backend-entrypoint.sh"]
CMD ["python", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
