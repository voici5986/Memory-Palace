# Input template for apply_profile.ps1. Do not copy this file directly.
# Phase 4 Profile A (Windows): low-spec local, keyword-only fallback.
DATABASE_URL=sqlite+aiosqlite:///C:/memory_palace/agent_memory.db
SEARCH_DEFAULT_MODE=keyword
RETRIEVAL_EMBEDDING_BACKEND=none
RETRIEVAL_RERANKER_ENABLED=false
RUNTIME_INDEX_WORKER_ENABLED=false
RUNTIME_INDEX_DEFER_ON_WRITE=false
RUNTIME_SESSION_FIRST_SEARCH=true
RUNTIME_AUTO_FLUSH_ENABLED=true

# HOLD defaults (#5/#6/#11/#12/#13)
EXTERNAL_IMPORT_ENABLED=false
EXTERNAL_IMPORT_ALLOWED_DOMAINS=notes
EXTERNAL_IMPORT_ALLOWED_ROOTS=
EXTERNAL_IMPORT_ALLOWED_EXTS=.md,.txt,.json
EXTERNAL_IMPORT_MAX_TOTAL_BYTES=5242880
EXTERNAL_IMPORT_MAX_FILES=200
EXTERNAL_IMPORT_RATE_LIMIT_WINDOW_SECONDS=60
EXTERNAL_IMPORT_RATE_LIMIT_MAX_REQUESTS=10
EXTERNAL_IMPORT_RATE_LIMIT_STATE_FILE=
EXTERNAL_IMPORT_REQUIRE_SHARED_RATE_LIMIT=false
AUTO_LEARN_EXPLICIT_ENABLED=false
AUTO_LEARN_ALLOWED_DOMAINS=notes
AUTO_LEARN_REQUIRE_REASON=true
EMBEDDING_PROVIDER_CHAIN_ENABLED=false
EMBEDDING_PROVIDER_FAIL_OPEN=false
EMBEDDING_PROVIDER_FALLBACK=hash
RETRIEVAL_SQLITE_VEC_ENABLED=false
RETRIEVAL_SQLITE_VEC_EXTENSION_PATH=
RETRIEVAL_VECTOR_ENGINE=legacy
RETRIEVAL_SQLITE_VEC_READ_RATIO=0
# Host profiles stay on delete journal mode to remain safer on copied or network-mounted paths.
RUNTIME_WRITE_WAL_ENABLED=false
RUNTIME_WRITE_JOURNAL_MODE=delete
RUNTIME_WRITE_WAL_SYNCHRONOUS=normal
RUNTIME_WRITE_BUSY_TIMEOUT_MS=5000
RUNTIME_WRITE_WAL_AUTOCHECKPOINT=1000
